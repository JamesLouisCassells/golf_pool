# Backend server address.
HTTP_ADDR=:8080

# Local Postgres connection string used by the Go API.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/golf_pool?sslmode=disable

# Temporary dev auth mode while the real Clerk browser flow is not wired yet.
MOCK_AUTH_ENABLED=true
MOCK_AUTH_CLERK_ID=dev-user
MOCK_AUTH_EMAIL=dev@example.com
MOCK_AUTH_NAME='Dev User'
MOCK_AUTH_ADMIN=false

# Clerk values for the real auth flow.
# Preferred plan:
# - Clerk in the frontend for browser auth/session state
# - local JWT verification in the backend via JWKS
# - custom session claims for email, display name, and admin role
# - Backend API lookups only as a fallback when claims are missing
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173
# These should match any custom session token claims configured in Clerk.
CLERK_EMAIL_CLAIM=email
CLERK_NAME_CLAIM=name
CLERK_ADMIN_CLAIM=role
CLERK_ADMIN_VALUE=admin

# Optional golf provider refresh config. When this is omitted, the admin
# refresh endpoint only accepts manual pasted result snapshots.
GOLF_PROVIDER=
GOLF_API_BASE_URL=https://live-golf-data.p.rapidapi.com
GOLF_API_KEY=
GOLF_API_HOST=live-golf-data.p.rapidapi.com
